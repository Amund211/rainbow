{
    "name": "rainbow",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "imports": {
        "#*": "./src/*"
    },
    "scripts": {
        "dev:staging": "vite --mode proxy-staging",
        "dev:production": "vite --mode proxy-production",
        "tsc": "tsgo -p tsconfig.app.json",
        "tsc:watch": "tsgo -w -p tsconfig.app.json",
        "vite:build": "vite build",
        "build": "run-p tsc vite:build",
        "oxfmt:check": "oxfmt --check",
        "oxfmt:write": "oxfmt",
        "eslint:check": "eslint --cache .",
        "eslint:write": "eslint --cache --fix .",
        "lint:check": "run-p eslint:check oxfmt:check",
        "lint:fix": "run-s oxfmt:write eslint:write",
        "test": "vitest run --browser.headless",
        "test:unit": "vitest run --project unit",
        "test:ui": "vitest run --project ui --browser.headless",
        "test:ui:chromium": "vitest run --project ui --browser.headless --browser=chromium",
        "test:ui:webkit": "vitest run --project ui --browser.headless --browser=webkit --no-file-parallelism",
        "test:watch": "vitest",
        "test:watch:unit": "vitest --project unit",
        "test:watch:ui": "vitest --project ui",
        "test:coverage": "vitest run --coverage --browser.headless",
        "preview": "vite preview",
        "knip": "knip",
        "knip:fix": "knip --fix"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/roboto": "^5.2.10",
        "@mui/icons-material": "^7.3.9",
        "@mui/material": "^7.0.1",
        "@mui/x-date-pickers": "^8.27.2",
        "@sentry/react": "^10.46.0",
        "@sentry/vite-plugin": "^5.1.1",
        "@tanstack/react-query": "^5.95.2",
        "@tanstack/react-query-persist-client": "^5.95.2",
        "@tanstack/react-router": "^1.168.8",
        "dayjs": "^1.11.20",
        "html-to-image": "^1.11.13",
        "idb-keyval": "^6.2.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "recharts": "^3.8.1",
        "ua-parser-js": "^2.0.9",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@rolldown/plugin-babel": "^0.2.2",
        "@tanstack/eslint-plugin-query": "^5.97.0",
        "@tanstack/react-query-devtools": "^5.95.2",
        "@tanstack/react-router-devtools": "^1.166.11",
        "@tanstack/router-plugin": "^1.167.9",
        "@types/node": "^24.12.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260410.1",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/browser-playwright": "^4.1.2",
        "@vitest/coverage-v8": "^4.1.2",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9.39.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "knip": "^5.86.0",
        "msw": "^2.12.14",
        "npm-run-all": "^4.1.5",
        "oxfmt": "^0.42.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.1",
        "vite": "^8.0.5",
        "vite-plugin-react-click-to-component": "^4.2.1",
        "vitest": "^4.1.0",
        "vitest-browser-react": "^2.1.0"
    },
    "packageManager": "pnpm@10.33.0"
}
