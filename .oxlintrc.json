{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": [
        "typescript",
        "unicorn",
        "oxc",
        "react",
        "jsx-a11y",
        "import",
        "vitest",
        "node",
        "promise"
    ],
    "jsPlugins": [
        "@tanstack/eslint-plugin-query",
        {
            "name": "react-hooks-js",
            "specifier": "eslint-plugin-react-hooks"
        }
    ],
    "ignorePatterns": ["src/routeTree.gen.ts"],
    "categories": {
        "correctness": "error",
        "pedantic": "error",
        "perf": "error",
        "restriction": "error",
        "style": "error",
        "suspicious": "error"
    },
    "options": {
        "typeAware": true,
        "typeCheck": true,
        "reportUnusedDisableDirectives": "error"
    },
    "rules": {
        "typescript/consistent-return": "off",
        "eslint/array-callback-return": "off",
        "unicorn/no-array-callback-reference": "off",
        "promise/always-return": "off",
        "typescript/no-unsafe-type-assertion": "off",
        "react/react-in-jsx-scope": "off",
        "unicorn/consistent-function-scoping": "off",
        "unicorn/prefer-set-has": "off",
        "eslint/no-warning-comments": "off",
        "eslint/max-lines-per-function": "off",
        "eslint/no-inline-comments": "off",
        "eslint/max-lines": "off",
        "eslint/max-classes-per-file": "off",
        "oxc/no-optional-chaining": "off",
        "oxc/no-rest-spread-properties": "off",
        "eslint/no-undefined": "off",
        "eslint/no-negated-condition": "off",
        "unicorn/no-useless-undefined": "off",
        "oxc/no-async-await": "off",
        "eslint/require-await": "off",
        "react/no-multi-comp": "off",
        "eslint/default-case": "off",
        "eslint/complexity": "off",
        "eslint/no-void": "off",
        "import/no-named-export": "off",
        "import/group-exports": "off",
        "import/exports-last": "off",
        "import/prefer-default-export": "off",
        "import/max-dependencies": "off",
        "eslint/no-magic-numbers": "off",
        "eslint/sort-keys": "off",
        "react/jsx-max-depth": "off",
        "eslint/no-ternary": "off",
        "eslint/arrow-body-style": "off",
        "unicorn/no-null": "off",
        "eslint/id-length": "off",
        "eslint/max-statements": "off",
        "eslint/capitalized-comments": "off",
        "unicorn/no-zero-fractions": "off",
        "eslint/no-continue": "off",
        "eslint/max-params": "off",
        "unicorn/prefer-ternary": "off",
        "eslint/init-declarations": "off",
        "typescript/explicit-module-boundary-types": "off",
        "typescript/explicit-function-return-type": "off",

        // TODO: Re-enable

        "eslint/no-console": "off",
        "typescript/no-import-type-side-effects": "off",
        "eslint/no-use-before-define": "off",
        "eslint/no-plusplus": "off",
        "unicorn/no-array-reduce": "off",
        "eslint/no-eq-null": "off",
        "unicorn/no-array-for-each": "off",
        "promise/catch-or-return": "off",
        "eslint/no-param-reassign": "off",
        "vitest/require-test-timeout": "off",
        "vitest/no-importing-vitest-globals": "off",
        "vitest/prefer-describe-function-title": "off",
        "vitest/prefer-to-be-truthy": "off",
        "vitest/prefer-to-be-falsy": "off",
        "import/consistent-type-specifier-style": "off",
        // Disable in main.tsx?
        "import/no-unassigned-import": "off",
        "import/first": "off",
        // **********
        "import/no-default-export": "off",
        "import/no-duplicates": "off",
        "import/unambiguous": "off",
        "import/no-namespace": "off",
        "import/no-named-as-default": "off",
        "eslint/sort-imports": "off",
        "unicorn/switch-case-braces": "off",
        "unicorn/prefer-global-this": "off",
        "promise/prefer-await-to-then": "off",
        "unicorn/numeric-separators-style": "off",
        // TODO: Decide on function style and fix or disable rule
        "eslint/func-style": "off",
        "unicorn/prefer-spread": "off",
        "promise/prefer-await-to-callbacks": "off",
        // TODO: Decide on filename case and fix or disable rule
        "unicorn/filename-case": "off",
        "eslint/prefer-destructuring": "off",
        "typescript/consistent-type-imports": "off",
        // NOTE: Weird behavior in src/charts/history/data.unit.test.ts
        "eslint/no-implicit-coercion": "off",
        "react/jsx-props-no-spreading": "off",
        "unicorn/no-nested-ternary": "off",
        "eslint/no-nested-ternary": "off",
        // NOTE: We have a few cases where we don't use the setter - either ignore it for them, or find a different solution
        "react/hook-use-state": "off",
        "promise/no-nesting": "off",
        "react/jsx-curly-brace-presence": "off",
        "eslint/object-shorthand": "off",
        "promise/avoid-new": "off",
        "eslint/no-duplicate-imports": "off",
        "eslint/new-cap": "off",
        "typescript/prefer-readonly": "off",
        "eslint/prefer-exponentiation-operator": "off",

        // Jest rules got enabled with vitest for some reason
        "jest/require-hook": "off",
        "jest/require-top-level-describe": "off",
        "jest/no-hooks": "off",
        "jest/no-export": "off",
        "jest/no-disabled-tests": "off",
        "jest/expect-expect": "off",

        "react/jsx-filename-extension": [
            "error",
            {
                // "allow": "as-needed",
                "extensions": ["tsx"]
            }
        ],
        "eslint/curly": ["error", "multi-line", "consistent"],

        "@tanstack/query/exhaustive-deps": "error",
        "@tanstack/query/no-rest-destructuring": "error",
        "@tanstack/query/stable-query-client": "error",
        "@tanstack/query/no-unstable-deps": "error",
        "@tanstack/query/infinite-query-property-order": "error",
        "@tanstack/query/no-void-query-fn": "error",
        "@tanstack/query/mutation-property-order": "error",
        "@tanstack/query/prefer-query-options": "error",

        "react-hooks-js/config": "error",
        "react-hooks-js/error-boundaries": "error",
        "react-hooks-js/component-hook-factories": "error",
        "react-hooks-js/gating": "error",
        "react-hooks-js/globals": "error",
        "react-hooks-js/immutability": "error",
        "react-hooks-js/preserve-manual-memoization": "error",
        "react-hooks-js/purity": "error",
        "react-hooks-js/refs": "error",
        "react-hooks-js/set-state-in-effect": "error",
        "react-hooks-js/set-state-in-render": "error",
        "react-hooks-js/static-components": "error",
        "react-hooks-js/unsupported-syntax": "error",
        "react-hooks-js/use-memo": "error",
        "react-hooks-js/incompatible-library": "error"
    },
    "env": {
        "builtin": true
    },
    "overrides": [
        {
            "files": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/mocks/**"],
            "rules": {
                "unicorn/prefer-type-error": "off"
            }
        },
        {
            "files": ["src/**/*.unit.test.ts"],
            "rules": {
                "import/no-nodejs-modules": "off"
            }
        },
        {
            "files": ["vite.config.ts", "vitest.config.ts"],
            "rules": {
                "import/no-default-export": "off",
                "import/no-nodejs-modules": "off",
                "node/no-process-env": "off"
            }
        },
        {
            "files": ["src/schemas/**/*.ts"],
            "rules": {
                // The rule incorrectly flags zod's catch method
                "unicorn/prefer-top-level-await": "off"
            }
        }
    ]
}
