{
    "plugins": [
        "eslint",
        "typescript",
        "unicorn",
        "oxc",
        "react",
        "react-perf",
        "import",
        "jsdoc",
        "promise",
        "vitest"
    ],
    "categories": {
        "correctness": "error",
        "suspicious": "error",
        "pedantic": "error",
        "perf": "error",
        "style": "error",
        "restriction": "error",
        "nursery": "error"
    },
    "options": {
        "typeAware": true
    },
  "rules": {
    "vitest/no-importing-vitest-globals": "off"
  }
}
